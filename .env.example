# ── Glean ─────────────────────────────────────────────────────────
GLEAN_INSTANCE=your-company
GLEAN_SERVER_URL=https://your-company-be.glean.com
GLEAN_API_TOKEN=your-glean-api-token
GLEAN_INDEXING_API_TOKEN=your-glean-indexing-token

# ── Slack ─────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
TEST_CHANNEL=YOUR_TEST_CHANNEL_ID
ERROR_CHANNEL=YOUR_ERROR_CHANNEL_ID
USE_TEST_CHANNEL=true

# ── Google ────────────────────────────────────────────────────────
# Path to service account JSON with Sheets read access
GOOGLE_CREDENTIALS_PATH=google-credentials.json
